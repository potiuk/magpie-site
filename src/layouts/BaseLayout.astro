---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  /** GitHub edit URL of the source this page is generated from. When set,
   *  a floating "Suggest a change" button links to it (opens GitHub's
   *  editor, which forks + proposes a PR for non-collaborators). */
  editUrl?: string;
  /** Site-root-relative path to the social-share (Open Graph) image.
   *  Defaults to the branded 1200×630 card. */
  image?: string;
}

const {
  title = "Apache Magpie — Give maintainers time back",
  description = "AI-powered assistant for open-source maintainers. Triage, mentor, draft, pair, and auto-merge under Apache Software Foundation governance.",
  editUrl,
  image = "/og-image.png",
} = Astro.props;

// Absolute URLs for social-share (Open Graph / Twitter) tags. Scrapers require
// absolute image URLs, so resolve against the configured `site`. The default is
// the 1200×630 branded social card (public/og-image.png); individual pages may
// pass their own `image` (a site-root-relative path) to override it.
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(
  `${import.meta.env.BASE_URL.replace(/\/$/, "")}${image}`,
  Astro.site,
).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/favicon.svg`} />
    {/* ICO fallback for clients that don't use the SVG icon (Safari, some
        link/tab unfurlers), which otherwise request /favicon.ico implicitly. */}
    <link rel="icon" type="image/x-icon" sizes="any" href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/favicon.ico`} />
    {/* Inter, Jost and Geist are self-hosted via Fontsource (src/styles/global.css);
        no external font CDN is loaded (apache/magpie-site#11). */}
    <title>{title}</title>
    {/* Social-share preview (Open Graph + Twitter Card): show the branded Magpie
        card, not the framework default, when links are unfurled on social media. */}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Apache Magpie" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {/* ASF Matomo analytics (site id 89), as issued by the ASF Privacy team
        (privacy@apache.org). Cookieless and Do-Not-Track-respecting per ASF
        policy; the tracker is self-hosted at analytics.apache.org. The Privacy
        team recommends placing this immediately before </head>. is:inline keeps
        it verbatim so Astro does not bundle/transform it. */}
    <script is:inline>
      var _paq = (window._paq = window._paq || []);
      /* tracker methods like "setCustomDimension" should be called before "trackPageView" */
      _paq.push(["setDoNotTrack", true]);
      _paq.push(["disableCookies"]);
      _paq.push(["trackPageView"]);
      _paq.push(["enableLinkTracking"]);
      (function () {
        var u = "https://analytics.apache.org/";
        _paq.push(["setTrackerUrl", u + "matomo.php"]);
        _paq.push(["setSiteId", "89"]);
        var d = document,
          g = d.createElement("script"),
          s = d.getElementsByTagName("script")[0];
        g.async = true;
        g.src = u + "matomo.js";
        s.parentNode.insertBefore(g, s);
      })();
    </script>
  </head>
  <body>
    <slot />
    {editUrl && (
      <a
        href={editUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="suggest-change"
        aria-label="Suggest a change to this page on GitHub"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 20h9" />
          <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z" />
        </svg>
        <span class="suggest-change-label">Suggest a change</span>
      </a>
    )}
  </body>
</html>

<style>
  .suggest-change {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 50;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    border-radius: 9999px;
    background: var(--color-brand-600, #004aad);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1;
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(0, 38, 84, 0.28);
    transition: background-color 0.15s ease, transform 0.15s ease;
  }
  .suggest-change:hover {
    background: var(--color-brand-700, #003a87);
    transform: translateY(-1px);
  }
  @media (max-width: 640px) {
    .suggest-change {
      bottom: 1rem;
      right: 1rem;
      padding: 0.625rem;
    }
    .suggest-change-label {
      display: none;
    }
  }
</style>
