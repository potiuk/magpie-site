---
import BaseLayout from "./BaseLayout.astro";
import { getCollection } from "astro:content";
import { SiteHeader } from "../components/landing/SiteHeader";
import { SiteFooter } from "../components/landing/SiteFooter";
import DocsNavTree from "../components/docs/DocsNavTree.astro";
import type { TreeNode } from "../components/docs/DocsNavTree.astro";
import toolsData from "../data/tools.json";

interface Props {
  title?: string;
  currentSlug: string;
  /** GitHub edit URL for this page's source (forwarded to BaseLayout). */
  editUrl?: string;
}

const { title, currentSlug, editUrl } = Astro.props;

// Internal governance drafts that should not appear on the public site.
const HIDDEN_DOCS = new Set(["board-resolution-draft"]);
// Quick-start entry pinned to the top of the docs sidebar.
const QUICK_START = { slug: "setup/install-recipes", label: "Quick Start" };

// Curated nav grouping — mirrors the landing's skill families. "_root" holds
// the top-level getting-started docs. Unlisted groups fall to the end.
const GROUP_META: Record<string, { label: string; order: number }> = {
  _root: { label: "Getting Started", order: 0 },
  education: { label: "Education", order: 1 },
  // The training module is a self-contained sub-section of education (an
  // LMS-neutral course wrapping the progression pages); give it its own
  // sidebar heading so its README is one Overview, not a second one folded
  // into Education. See NESTED_GROUPS.
  "education/training": { label: "Training", order: 1.5 },
  setup: { label: "Setup", order: 2 },
  security: { label: "Security", order: 3 },
  "pr-management": { label: "PR Management", order: 4 },
  "issue-management": { label: "Issue Management", order: 5 },
  "repo-health": { label: "Repo Health", order: 6 },
  "release-management": { label: "Release Management", order: 7 },
  mentoring: { label: "Mentoring", order: 8 },
  "contributor-growth": { label: "Contributor Growth", order: 9 },
  pairing: { label: "Pairing", order: 10 },
  adapters: { label: "Adapters", order: 11 },
  tools: { label: "Tools", order: 12 },
  rfcs: { label: "RFCs", order: 13 },
};

// Logical page order within a group (by last path segment). The Overview
// (index / README) always leads; unlisted pages follow alphabetically.
const PAGE_ORDER: Record<string, string[]> = {
  _root: ["index", "prerequisites", "vendor-neutrality", "extending", "modes", "mode-economics", "spec-driven-development", "labels-and-capabilities", "editorial-guidelines", "confidentiality"],
  education: ["readme", "your-first-skill", "pattern-catalogue", "eval-driven-development", "workshops"],
  "education/training": ["readme", "lesson-01-what-agents-are", "lesson-02-working-with-agents", "lesson-03-choosing-models", "lesson-04-your-first-skill", "lesson-05-writing-safe-skills"],
  setup: ["readme", "install-recipes", "secure-agent-setup", "secure-agent-internals", "sandbox-troubleshooting", "agentic-overrides", "privacy-llm", "unadopt"],
  security: ["readme", "roles", "process", "threat-model", "new-members-onboarding", "how-to-fix-a-security-issue", "forwarder-routing-policy"],
  "release-management": ["readme", "process", "spec"],
  mentoring: ["readme", "spec"],
};

const prettify = (s: string) => s.replace(/-/g, " ");
const lastSeg = (id: string) => id.split("/").pop()!.replace(/\.md$/, "");
const pageLabel = (entry: { id: string; data: { title?: string } }) => {
  const seg = lastSeg(entry.id);
  if (seg === "index" || seg === "readme") return "Overview";
  return entry.data.title ?? prettify(seg);
};
// RFC nav labels: a bit more than the bare number, but short enough to fit the
// sidebar — "<num> · <short title>" derived from the page H1.
const firstH1 = (body: string | undefined): string | null => {
  const m = (body ?? "").replace(/<!--[\s\S]*?-->/g, "").match(/^#\s+(.+?)\s*$/m);
  return m ? m[1].trim() : null;
};
const shortRfc = (entry: { id: string; body?: string }) => {
  const m = (firstH1(entry.body) ?? "").match(/RFC-[A-Z]+-(\d+):\s*(.+)/);
  if (!m) return prettify(lastSeg(entry.id));
  let title = m[2].trim();
  if (title.length > 24) title = title.slice(0, 23).replace(/\s\S*$/, "") + "…";
  return `${m[1]} · ${title}`;
};
const escapeRe = (s: string) => s.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
// Character offset of the first link to `slug` in a section overview's body —
// i.e. the order its README / table of contents presents that page. -1 if the
// overview never links it. The negative-lookahead stops a slug matching a
// longer sibling (e.g. `.../agentic-work` must not match `.../agentic-work-x`).
const overviewOrder = (body: string | undefined, slug: string): number => {
  if (!body) return -1;
  return body.search(new RegExp(`docs/${escapeRe(slug)}(?![\\w-])`));
};
// Sidebar order within a group: the Overview (README/index) leads; then pages
// in the order the section's README links them (so the sidebar tracks the doc's
// own table of contents); then the curated PAGE_ORDER as a fallback for pages
// the README doesn't link; then alphabetical. Mirrors the /docs index page.
const pageRank = (groupKey: string, slug: string, overviewBody?: string) => {
  const seg = lastSeg(slug);
  if (seg === "index" || seg === "readme") return -1;
  const off = overviewOrder(overviewBody, slug);
  if (off >= 0) return off; // README reading order (offsets are well under 1e6)
  const i = (PAGE_ORDER[groupKey] ?? []).indexOf(seg);
  if (i !== -1) return 1_000_000 + i; // curated fallback
  return 2_000_000; // unlisted — alphabetical via the secondary sort key
};

const all = (await getCollection("docs")).filter(
  (entry) => !HIDDEN_DOCS.has(entry.id.replace(/\.md$/, "")),
);

type NavItem = { slug: string; label: string; rank: number };
type NavGroup = { name: string; label: string; order: number; items: NavItem[]; overviewBody?: string };
// Sub-sections that live under another group's directory but get their own
// sidebar heading (keyed by their two-segment path). Everything else groups by
// its top-level directory.
const NESTED_GROUPS = new Set(["education/training"]);
const groups = new Map<string, NavGroup>();
for (const entry of all) {
  const parts = entry.id.split("/");
  const two = parts.slice(0, 2).join("/");
  const groupKey = NESTED_GROUPS.has(two)
    ? two
    : parts.length > 1
      ? parts[0]
      : "_root";
  if (!groups.has(groupKey)) {
    groups.set(groupKey, {
      name: groupKey,
      label: GROUP_META[groupKey]?.label ?? prettify(groupKey),
      order: GROUP_META[groupKey]?.order ?? 99,
      items: [],
    });
  }
  const slug = entry.id.replace(/\.md$/, "");
  const group = groups.get(groupKey)!;
  // Keep the section overview's body so page order can follow its README.
  const seg = lastSeg(slug);
  // A group's overview is the README/index sitting directly in the group's own
  // directory (education/README for education, education/training/README for
  // training). Deeper READMEs — e.g. tools/<name>/readme — are not overviews.
  const dir = parts.slice(0, -1).join("/") || "_root";
  if ((seg === "index" || seg === "readme") && dir === groupKey) {
    group.overviewBody = entry.body;
  }
  // Tool pages (tools/<name>/readme) are one overview per tool — label them by
  // the tool name, not the generic "Overview".
  const label =
    groupKey === "tools"
      ? (parts[1] ?? pageLabel(entry))
      : groupKey === "rfcs"
        ? shortRfc(entry)
        : pageLabel(entry);
  // rank is filled in after the loop, once every group's overview body is known.
  group.items.push({ slug, label, rank: 0 });
}
const sortedGroups = Array.from(groups.values()).sort(
  (a, b) => a.order - b.order || a.name.localeCompare(b.name),
);
for (const g of sortedGroups) {
  for (const it of g.items) it.rank = pageRank(g.name, it.slug, g.overviewBody);
  g.items.sort((a, b) => a.rank - b.rank || a.label.localeCompare(b.label));
}

// --- Collapsible nav tree -------------------------------------------------
// Turn each section's flat page list into a nested tree keyed by the page's
// path segments (so it goes exactly as deep as the content: tools/<name>/readme
// nests two levels), then bucket the many tools by kind and gather the sections
// under a few super-categories. The result is rendered by DocsNavTree, which
// folds everything except the branch leading to the current page.

// Internal node shape: TreeNode plus sort/build bookkeeping fields (ignored by
// the renderer).
type BuildNode = TreeNode & { _seg?: string; _order?: number; children?: BuildNode[] };

// tool name → "contract" | "substrate", used to split the Tools section.
const TOOL_KIND = new Map<string, string>(
  ((toolsData as { tools?: { name: string; kind: string }[] }).tools ?? []).map(
    (t) => [t.name, t.kind],
  ),
);

// Build the child nodes for one section from its (already-ordered) page items.
const buildSection = (group: NavGroup): BuildNode[] => {
  const strip = group.name === "_root" ? 0 : group.name.split("/").length;
  const roots: BuildNode[] = [];
  for (const item of group.items) {
    const rel = item.slug.split("/").slice(strip);
    let siblings = roots;
    rel.forEach((seg, i) => {
      const isLeaf = i === rel.length - 1;
      let node = siblings.find((n) => n._seg === seg);
      if (!node) {
        node = { _seg: seg, label: "", _order: item.rank, children: [] };
        siblings.push(node);
      }
      if (isLeaf) {
        node.href = item.slug;
        // Tool leaves are the tool's README → label it "Overview"; the tool
        // name lives on the directory node above. Everything else keeps the
        // label already computed for the flat list.
        node.label = group.name === "tools" ? "Overview" : item.label;
        node._order = item.rank;
        node.isCurrent = item.slug === currentSlug;
      } else if (!node.label) {
        // Directory node: keep the raw segment for tool names (recognisable
        // identifiers); prettify everything else.
        node.label = group.name === "tools" ? seg : prettify(seg);
      }
      siblings = node.children!;
    });
  }
  return roots;
};

// Bucket a section's direct children (tool directories) by kind.
const bucketTools = (toolDirs: BuildNode[]): BuildNode[] => {
  const groupsByKind: Record<string, BuildNode[]> = { contract: [], substrate: [], other: [] };
  for (const dir of toolDirs) (groupsByKind[TOOL_KIND.get(dir._seg ?? "") ?? "other"]).push(dir);
  const bucket = (label: string, dirs: BuildNode[], order: number): BuildNode | null =>
    dirs.length ? { label: `${label} (${dirs.length})`, _order: order, children: dirs } : null;
  return [
    bucket("Contracts", groupsByKind.contract, 0),
    bucket("Substrates", groupsByKind.substrate, 1),
    bucket("Other", groupsByKind.other, 2),
  ].filter((n): n is BuildNode => n !== null);
};

// Section (top-level group) key → its built node, ready to slot under a
// super-category.
const sectionNodes = new Map<string, BuildNode>();
for (const g of sortedGroups) {
  let children = buildSection(g);
  if (g.name === "tools") children = bucketTools(children);
  sectionNodes.set(g.name, { label: g.label, children });
}

// Super-categories: a shallow top level so the ~15 sections aren't all at the
// root. Any section not listed here is appended to the last category so nothing
// is ever dropped.
const SUPER_CATEGORIES: { label: string; sections: string[] }[] = [
  { label: "Start here", sections: ["_root", "setup"] },
  { label: "Learn", sections: ["education", "education/training"] },
  {
    label: "Maintainer workflows",
    sections: [
      "pr-management", "issue-management", "security", "repo-health",
      "release-management", "mentoring", "contributor-growth", "pairing",
    ],
  },
  { label: "Extend & reference", sections: ["adapters", "tools", "rfcs", "skill-sources", "utilities"] },
];
const placed = new Set(SUPER_CATEGORIES.flatMap((c) => c.sections));
const leftovers = sortedGroups.map((g) => g.name).filter((n) => !placed.has(n));
SUPER_CATEGORIES[SUPER_CATEGORIES.length - 1].sections.push(...leftovers);

const navTree: BuildNode[] = SUPER_CATEGORIES.map((cat, order) => ({
  label: cat.label,
  _order: order,
  children: cat.sections
    .map((key, i) => {
      const node = sectionNodes.get(key);
      if (node) node._order = i;
      return node;
    })
    .filter((n): n is BuildNode => n !== undefined),
})).filter((cat) => cat.children!.length > 0);

// Sort every node's children by rank then label (directories inherit their
// earliest descendant's rank), and mark the branch that holds the current page
// so the renderer can open exactly that path.
const finalize = (node: BuildNode): { order: number; hasCurrent: boolean } => {
  if (!node.children || node.children.length === 0) {
    return { order: node._order ?? 2_000_000, hasCurrent: !!node.isCurrent };
  }
  let minOrder = Infinity;
  let hasCurrent = !!node.isCurrent;
  for (const child of node.children) {
    const r = finalize(child);
    minOrder = Math.min(minOrder, r.order);
    hasCurrent = hasCurrent || r.hasCurrent;
  }
  if (node._order === undefined) node._order = minOrder;
  node.children.sort(
    (a, b) => (a._order ?? 0) - (b._order ?? 0) || a.label.localeCompare(b.label),
  );
  node.hasCurrent = hasCurrent;
  return { order: node._order, hasCurrent };
};
for (const cat of navTree) finalize(cat);

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout title={title ? `${title} — Apache Magpie Docs` : "Apache Magpie Docs"} editUrl={editUrl}>
  <SiteHeader />
  <div class="flex w-full">
    <aside class="w-64 flex-none border-r border-neutral-200 bg-neutral-50 sticky top-0 h-screen flex flex-col mobile:hidden">
      {/* Pinned header: stays put while the nav below scrolls. */}
      <div class="flex-none border-b border-neutral-200 px-5 pt-6 pb-4">
        <a href={`${base}/`} class="block text-caption font-caption text-brand-600 hover:text-brand-700">← Back to Apache Magpie™</a>
        <div class="mt-1 text-heading-3 font-heading-3 text-default-font">Documentation</div>
      </div>
      <div id="docs-nav-scroll" class="relative flex-1 overflow-y-auto px-5 py-5">
        <a
          href={`${base}/docs/${QUICK_START.slug}`}
          aria-current={currentSlug === QUICK_START.slug ? "page" : undefined}
          class={`block mb-5 px-3 py-2 rounded-md text-body-bold font-body-bold ${currentSlug === QUICK_START.slug ? "bg-brand-600 text-white" : "bg-brand-50 text-brand-700 hover:bg-brand-100"}`}
        >
          ⚡ {QUICK_START.label}
        </a>
        <nav>
          <DocsNavTree nodes={navTree} base={base} level={0} />
        </nav>
      </div>
    </aside>
    <main class="flex-1 px-12 py-12 mobile:px-4 mobile:py-8">
      <article class="prose prose-neutral max-w-3xl mx-auto">
        <slot />
      </article>
    </main>
  </div>
  <SiteFooter />

  {/* On a long sidebar the active page can be scrolled out of view after a
      full-page navigation. Bring it back into the sidebar's scroll viewport
      (scrolling only the nav region, not the window) so you keep your place. */}
  <script is:inline>
    (() => {
      const scroller = document.getElementById("docs-nav-scroll");
      const active = scroller?.querySelector('[aria-current="page"]');
      if (!scroller || !active) return;
      const target =
        active.offsetTop - scroller.clientHeight / 2 + active.offsetHeight / 2;
      scroller.scrollTop = Math.max(0, target);
    })();
  </script>
</BaseLayout>

<style is:global>
  .prose h1 { font-size: 2rem; font-weight: 700; margin-top: 0; margin-bottom: 1rem; color: var(--color-default-font); }
  .prose h2 { font-size: 1.5rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.75rem; color: var(--color-default-font); }
  .prose h3 { font-size: 1.25rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.5rem; color: var(--color-default-font); }
  .prose p { margin: 0.75rem 0; color: var(--color-default-font); line-height: 1.7; }
  .prose a { color: var(--color-brand-600); text-decoration: none; }
  .prose a:hover { color: var(--color-brand-700); text-decoration: underline; }
  .prose ul, .prose ol { margin: 0.75rem 0; padding-left: 1.5rem; color: var(--color-default-font); }
  .prose li { margin: 0.25rem 0; }
  .prose code { background: var(--color-neutral-100); padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-size: 0.875em; }
  .prose pre { background: var(--color-neutral-900); color: var(--color-neutral-50); padding: 1rem; border-radius: 0.5rem; overflow-x: auto; margin: 1rem 0; }
  .prose pre code { background: transparent; padding: 0; color: inherit; }
  .prose blockquote { border-left: 4px solid var(--color-brand-200); padding-left: 1rem; margin: 1rem 0; color: var(--color-subtext-color); font-style: italic; }
  .prose table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
  .prose th, .prose td { border: 1px solid var(--color-neutral-200); padding: 0.5rem 0.75rem; text-align: left; }
  .prose th { background: var(--color-neutral-50); font-weight: 600; }
  .prose img { max-width: 100%; height: auto; border-radius: 0.5rem; margin: 1rem 0; }
  .prose hr { border: none; border-top: 1px solid var(--color-neutral-200); margin: 2rem 0; }
</style>
