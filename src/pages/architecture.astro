---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SiteHeader } from "../components/landing/SiteHeader";
import { SiteFooter } from "../components/landing/SiteFooter";
import VendorIcon from "../components/VendorIcon.astro";
import { buildToolsView, type VendorNeutrality } from "../lib/tools-view";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Shared tools/orgs/vendor view-model — the same source the dedicated /tools
// page uses, so the two never drift. This page consumes only the slices its
// remaining sections need (the full tool browser now lives at /tools).
const {
  data,
  skillCaps,
  contractList,
  substrateList,
  visibleOrgs,
  vendorLogo,
  orgLogoOf,
} = buildToolsView(base);

// --- vendor neutrality ---------------------------------------------------
const vn = data.vendorNeutrality;

// Neutrality-class badge styling for the per-contract score cards.
const CLASS_STYLE: Record<string, string> = {
  "vendor-backed": "bg-brand-50 text-brand-700 border-brand-200",
  agnostic: "bg-neutral-100 text-neutral-700 border-neutral-200",
  "single-org": "bg-neutral-100 text-neutral-700 border-neutral-200",
};
const CLASS_LABEL: Record<string, string> = {
  "vendor-backed": "vendor-backed",
  agnostic: "agnostic",
  "single-org": "single-org",
};
// Skills grouped into the three neutrality buckets, for the per-bucket lists.
const VERDICT_META = [
  {
    key: "capability-pure",
    label: "Capability-pure",
    def: "names no backend at all",
    tone: "success" as const,
  },
  {
    key: "portable",
    label: "Portable",
    def: "every backend it invokes is swappable",
    tone: "success" as const,
  },
  {
    key: "vendor-coupled",
    label: "Vendor-coupled",
    def: "reaches for a capability's sole backend",
    tone: "error" as const,
  },
];
const skillsByVerdict = Object.fromEntries(
  VERDICT_META.map((v) => [v.key, vn.skills.list.filter((s) => s.verdict === v.key)]),
);
const shortContract = (c: string) => c.replace(/^contract:/, "");

// LLM-integration axis: group substrate tools by their agent-harness verdict.
const HARNESS_VERDICT_META = [
  { key: "agnostic", label: "Harness-agnostic", def: "runs under any agent harness", tone: "success" as const },
  { key: "portable", label: "Multi-harness", def: "supports two or more harnesses", tone: "success" as const },
  { key: "coupled", label: "Harness-coupled", def: "targets one harness today", tone: "error" as const },
];
type HarnessTool = NonNullable<VendorNeutrality["harness"]>["tools"][number];
const harnessByVerdict: Record<string, HarnessTool[]> = vn.harness
  ? Object.fromEntries(
      HARNESS_VERDICT_META.map((v) => [v.key, vn.harness!.tools.filter((t) => t.verdict === v.key)]),
    )
  : {};

const VENDOR_NEUTRALITY = `${base}/docs/vendor-neutrality`;
const EXTENDING = `${base}/docs/extending`;
const TAXONOMY = `${base}/docs/labels-and-capabilities`;
const ADAPTERS = `${base}/docs/adapters/registry`;
const SKILL_SOURCES_AUTHORING = `${base}/docs/skill-sources/authoring-a-source`;
const ORGANIZATIONS = "https://github.com/apache/magpie/tree/main/organizations";

// In-page section navigation. A section may carry `children` — sub-sections
// that render as an indented second level in the left nav (currently only
// Vendor neutrality). The full tool browser now lives on its own /tools page.
type NavSection = { id: string; label: string; children?: { id: string; label: string }[] };
const SECTIONS: NavSection[] = [
  { id: "model", label: "The model" },
  { id: "skill-capabilities", label: "Skill capabilities" },
  { id: "tool-capabilities", label: "Tool capabilities" },
  {
    id: "vendor-neutrality",
    label: "Vendor neutrality",
    children: [
      { id: "vn-per-contract", label: "Per-contract score" },
      { id: "vn-skills", label: "Skills by neutrality" },
      { id: "vn-llm", label: "LLM & agent neutrality" },
    ],
  },
  { id: "organizations", label: "Organizations" },
  { id: "extend", label: "Extending" },
];

// Full-bleed section band; alternating background for visual rhythm.
const band = "w-full px-8 py-16 mobile:px-4 mobile:py-12";
const inner = "mx-auto flex w-full max-w-[1100px] flex-col gap-5";
---

<BaseLayout
  title="Architecture — How Magpie is built"
  description="Apache Magpie's architecture: skills declare capabilities, tools provide contract and substrate interfaces, adapters implement them, and organizations bundle the defaults. Generated from the framework repo."
  editUrl="https://github.com/apache/magpie-site/edit/main/src/pages/architecture.astro"
>
  <SiteHeader />

  <main class="flex w-full flex-col items-center">
    <!-- Header band -->
    <div class="w-full bg-default-background px-8 pt-16 pb-10 mobile:px-4 mobile:pt-10">
      <header class="mx-auto flex w-full max-w-[1100px] flex-col gap-4">
        <a href={`${base}/`} class="text-body font-body text-brand-600 hover:text-brand-700">← Back to Magpie</a>
        <div class="flex items-center gap-2 self-start rounded-full border border-solid border-brand-200 bg-brand-50 px-4 py-1.5">
          <span class="text-caption font-caption text-brand-600">Architecture</span>
        </div>
        <h1 class="font-['Inter'] text-[38px] font-[700] leading-[44px] text-default-font -tracking-[0.035em] mobile:text-[28px]">
          How Magpie is built
        </h1>
        <p class="text-body font-body text-subtext-color max-w-[800px]">
          Four layers, one rule: <strong>workflows never name a vendor</strong>. Skills declare the{" "}
          <strong>capabilities</strong> they need; tools provide <strong>contract</strong> and{" "}
          <strong>substrate</strong> interfaces; <strong>adapters</strong> implement a contract for one backend;
          and <strong>organizations</strong> bundle the defaults a whole foundation or company shares. Everything
          on this page is generated directly from{" "}
          <a class="text-brand-600 hover:text-brand-700 underline" href="https://github.com/apache/magpie" target="_blank" rel="noreferrer">apache/magpie</a>,
          so it never drifts from the framework.
        </p>
        <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-caption font-caption text-subtext-color">
          <span><strong class="text-default-font">{skillCaps.length}</strong> skill capabilities</span>
          <span><strong class="text-default-font">{data.contractsTotal}</strong> tools across {Object.keys(data.contracts).length} contracts</span>
          <span><strong class="text-default-font">{data.substratesTotal}</strong> substrate tools</span>
          <span><strong class="text-default-font">{visibleOrgs.length}</strong> organizations</span>
          <span><strong class="text-default-font">{data.skills.total}</strong> skills</span>
          <span><strong class="text-success-700">{vn.overall.percent}%</strong> vendor-neutral</span>
        </div>
      </header>
    </div>

    <!-- Two-column: sticky left section nav (like the docs sidebar) + content -->
    <div class="flex w-full items-start">
      <aside class="w-64 flex-none border-r border-neutral-200 bg-neutral-50 sticky top-0 h-screen flex flex-col mobile:hidden">
        {/* Pinned header: stays put while the section list below scrolls. */}
        <div class="flex-none border-b border-neutral-200 px-5 pt-6 pb-4">
          <a href={`${base}/`} class="block text-caption font-caption text-brand-600 hover:text-brand-700">← Back to Magpie</a>
          <div class="mt-1 text-heading-3 font-heading-3 text-default-font">Architecture</div>
        </div>
        <nav class="relative flex flex-1 flex-col gap-0.5 overflow-y-auto px-3 py-4">
          {SECTIONS.map((s) => (
            <>
              <a
                data-arch-link={s.id}
                href={`#${s.id}`}
                class="block rounded-md px-3 py-1.5 text-body font-body text-default-font hover:bg-neutral-100"
              >
                {s.label}
              </a>
              {s.children?.map((c) => (
                <a
                  data-arch-link={c.id}
                  href={`#${c.id}`}
                  class="ml-3 block rounded-md border-l border-neutral-200 px-3 py-1 text-caption font-caption text-subtext-color hover:bg-neutral-100 hover:text-default-font"
                >
                  {c.label}
                </a>
              ))}
            </>
          ))}
        </nav>
      </aside>
      <div class="min-w-0 flex-1">

    <!-- The model -->
    <section id="model" class={`${band} bg-neutral-50 scroll-mt-14`}>
      <div class={inner}>
        <div class="flex flex-col gap-1">
          <h2 class="text-heading-2 font-heading-2 text-default-font">The model</h2>
          <p class="text-body font-body text-subtext-color max-w-[800px]">
            The four layers and how they connect. The seam between a workflow and a vendor is always a
            capability — so swapping a backend is a config change, never a rewrite.
          </p>
        </div>
        <div class="grid grid-cols-4 gap-4 mobile:grid-cols-1">
          <div class="flex flex-col gap-2 rounded-2xl border border-solid border-neutral-200 bg-default-background px-5 py-5 shadow-sm">
            <span class="text-body-bold font-body-bold text-default-font">1 · Skills</span>
            <span class="text-caption font-caption text-subtext-color">Generic English workflows the agent follows. They name a <span class="font-mono">capability:*</span> they need — never a vendor.</span>
          </div>
          <div class="flex flex-col gap-2 rounded-2xl border border-solid border-neutral-200 bg-default-background px-5 py-5 shadow-sm">
            <span class="text-body-bold font-body-bold text-default-font">2 · Capabilities</span>
            <span class="text-caption font-caption text-subtext-color">The contract between skills and tools. <span class="font-mono">capability:*</span> on skills; <span class="font-mono">contract:*</span> / <span class="font-mono">substrate:*</span> on tools.</span>
          </div>
          <div class="flex flex-col gap-2 rounded-2xl border border-solid border-neutral-200 bg-default-background px-5 py-5 shadow-sm">
            <span class="text-body-bold font-body-bold text-default-font">3 · Tools &amp; adapters</span>
            <span class="text-caption font-caption text-subtext-color">The only layer that knows a vendor. A <strong>contract</strong> is a pure interface; an <strong>adapter</strong> implements it for one backend.</span>
          </div>
          <div class="flex flex-col gap-2 rounded-2xl border border-solid border-neutral-200 bg-default-background px-5 py-5 shadow-sm">
            <span class="text-body-bold font-body-bold text-default-font">4 · Organizations</span>
            <span class="text-caption font-caption text-subtext-color">Bundle the defaults a whole foundation or company shares — governance vocabulary, backend choices, identity. Projects inherit them.</span>
          </div>
        </div>
        <div class="overflow-x-auto rounded-2xl border border-solid border-neutral-200 bg-default-background px-6 py-5">
          <pre class="font-mono text-caption text-subtext-color leading-relaxed">{`  SKILL  ──declares──▶  capability:triage ┐
                                          │  the capability is the only coupling
  TOOL   ──provides──▶  contract:tracker ─┘  (skills never branch on the backend)
            │
            ├─ contract:*   one per capability seam → an ADAPTER implements it for a vendor
            └─ substrate:*  framework plumbing (sandbox, privacy, analytics, …)

  ORGANIZATION (ASF, independent, …)  ──bundles──▶  which adapter fulfils each capability
                                                    + governance vocabulary + identity/logo`}</pre>
        </div>
      </div>
    </section>

    <!-- Skill capabilities -->
    <section id="skill-capabilities" class={`${band} bg-default-background scroll-mt-14`}>
      <div class={inner}>
        <div class="flex flex-col gap-1">
          <h2 class="text-heading-2 font-heading-2 text-default-font">Skill capabilities</h2>
          <p class="text-body font-body text-subtext-color max-w-[800px]">
            The workflow-lifecycle phase a skill performs (<span class="font-mono">capability:*</span>). A skill may carry more than one.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-3 mobile:grid-cols-1">
          {skillCaps.map((c) => (
            <div class="flex flex-col gap-1 rounded-xl border border-solid border-neutral-200 bg-default-background px-4 py-3">
              <span class="font-mono text-body-bold font-body-bold text-brand-700">capability:{c.key}</span>
              <span class="text-caption font-caption text-subtext-color">{c.def}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Tool capabilities: contracts + substrates -->
    <section id="tool-capabilities" class={`${band} bg-neutral-50 scroll-mt-14`}>
      <div class={inner}>
        <div class="flex flex-col gap-1">
          <h2 class="text-heading-2 font-heading-2 text-default-font">Tool capabilities</h2>
          <p class="text-body font-body text-subtext-color max-w-[800px]">
            What a tool provides. A <strong>contract</strong> is a capability seam with pluggable backends (where vendor
            neutrality is delivered); a <strong>substrate</strong> is framework plumbing shared by everything.
          </p>
          <a href={`${base}/tools`} class="inline-flex w-fit items-center gap-1.5 rounded-md border border-solid border-brand-300 bg-brand-50 px-3 py-1.5 text-caption font-caption text-brand-700 hover:border-brand-400 hover:bg-brand-100">
            Browse all {data.toolsTotal} tools →
          </a>
        </div>
        <div class="grid grid-cols-2 gap-6 mobile:grid-cols-1">
          <div class="flex flex-col gap-3">
            <h3 class="text-heading-3 font-heading-3 text-default-font">Contracts <span class="text-subtext-color">({contractList.length})</span></h3>
            {contractList.map((c) => (
              <div class="flex flex-col gap-1 rounded-xl border border-solid border-brand-200 bg-brand-50 px-4 py-3">
                <div class="flex items-center justify-between gap-2">
                  <span class="font-mono text-body-bold font-body-bold text-brand-700">contract:{c.key}</span>
                  <span class="rounded-full bg-default-background px-2 py-0.5 text-caption font-caption text-subtext-color">{c.count} tool{c.count === 1 ? "" : "s"}</span>
                </div>
                <span class="text-caption font-caption text-subtext-color">{c.def}</span>
              </div>
            ))}
          </div>
          <div class="flex flex-col gap-3">
            <h3 class="text-heading-3 font-heading-3 text-default-font">Substrates <span class="text-subtext-color">({substrateList.length})</span></h3>
            {substrateList.map((s) => (
              <div class="flex flex-col gap-1 rounded-xl border border-solid border-neutral-200 bg-default-background px-4 py-3">
                <div class="flex items-center justify-between gap-2">
                  <span class="font-mono text-body-bold font-body-bold text-neutral-700">substrate:{s.key}</span>
                  <span class="rounded-full bg-neutral-100 px-2 py-0.5 text-caption font-caption text-subtext-color">{s.count} tool{s.count === 1 ? "" : "s"}</span>
                </div>
                <span class="text-caption font-caption text-subtext-color">{s.def}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Vendor neutrality -->
    <section id="vendor-neutrality" class={`${band} bg-default-background scroll-mt-14`}>
      <div class={inner}>
        <div class="flex flex-col gap-1">
          <h2 class="text-heading-2 font-heading-2 text-default-font">Vendor neutrality</h2>
          <p class="text-body font-body text-subtext-color max-w-[820px]">
            Not a slogan — a <strong>deterministic score</strong>, computed straight from repository metadata by{" "}
            <a class="text-brand-600 hover:text-brand-700 underline" href="https://github.com/apache/magpie/tree/main/tools/vendor-neutrality-score" target="_blank" rel="noreferrer">tools/vendor-neutrality-score</a>{" "}
            and regenerated with this page, so the number cannot drift from the code. Neutrality is measured per{" "}
            <strong>capability contract</strong>: a contract is green once two or more backend vendors implement it,
            by construction when one spec serves every backend, or by exemption when it is bound to a single
            organization's data model.
          </p>
        </div>

        <!-- Score hero -->
        <div class="grid grid-cols-3 gap-4 mobile:grid-cols-1">
          <div class="flex flex-col justify-center gap-2 rounded-2xl border border-solid border-success-200 bg-success-50 px-6 py-6">
            <div class="flex items-baseline gap-2">
              <span class="font-['Inter'] text-[44px] font-[700] leading-none text-success-700">{vn.overall.green}<span class="text-[24px] text-success-600">/{vn.overall.total}</span></span>
              <span class="rounded-full bg-success-100 px-2.5 py-1 text-caption-bold font-caption-bold text-success-700">{vn.overall.percent}%</span>
            </div>
            <span class="text-body-bold font-body-bold text-default-font">capability contracts are vendor neutral</span>
            <div class="mt-1 h-2 w-full overflow-hidden rounded-full bg-success-100">
              <div class="h-full rounded-full bg-success-500" style={`width:${vn.overall.percent}%`}></div>
            </div>
          </div>
          <div class="col-span-2 flex flex-col justify-center gap-2 rounded-2xl border border-solid border-neutral-200 bg-neutral-50 px-6 py-6 mobile:col-span-1">
            <span class="text-body-bold font-body-bold text-default-font">
              {vn.skills.neutral} of {vn.skills.total} skills carry no vendor lock-in.
            </span>
            <p class="text-caption font-caption text-subtext-color max-w-[640px]">
              A skill is <strong>capability-pure</strong> when it names no backend, <strong>portable</strong> when
              every backend it invokes has an alternative, and <strong>vendor-coupled</strong> only when it reaches
              for the sole implementation of a capability. Swap in a second backend for that capability and every
              coupled skill becomes portable — without a line of skill code changing.
            </p>
            <div class="flex flex-wrap gap-2 pt-1">
              <span class="inline-flex items-center gap-1.5 rounded-full border border-solid border-success-200 bg-success-50 px-3 py-1 text-caption font-caption text-success-700"><strong>{vn.skills.byVerdict["capability-pure"] ?? 0}</strong> capability-pure</span>
              <span class="inline-flex items-center gap-1.5 rounded-full border border-solid border-success-200 bg-success-50 px-3 py-1 text-caption font-caption text-success-700"><strong>{vn.skills.byVerdict["portable"] ?? 0}</strong> portable</span>
              <span class="inline-flex items-center gap-1.5 rounded-full border border-solid border-error-200 bg-error-50 px-3 py-1 text-caption font-caption text-error-700"><strong>{vn.skills.byVerdict["vendor-coupled"] ?? 0}</strong> vendor-coupled</span>
            </div>
          </div>
        </div>

        <!-- Per-contract score table -->
        <h3 id="vn-per-contract" class="text-heading-3 font-heading-3 text-default-font pt-2 scroll-mt-14">Per-contract score</h3>
        <div class="grid grid-cols-2 gap-3 mobile:grid-cols-1">
          {vn.contracts.map((c) => (
            <div class={`flex flex-col gap-2 rounded-xl border border-solid px-4 py-3 ${c.green ? "border-success-200 bg-success-50/40" : "border-error-200 bg-error-50/50"}`}>
              <div class="flex items-start justify-between gap-2">
                <span class="font-mono text-body-bold font-body-bold text-default-font">{c.contract}</span>
                <span class={`flex-none rounded-full px-2 py-0.5 text-caption-bold font-caption-bold ${c.green ? "bg-success-100 text-success-700" : "bg-error-100 text-error-700"}`} title={c.green ? "Vendor neutral" : "Single-backend gap"}>{c.green ? "✓ neutral" : "✗ gap"}</span>
              </div>
              <div class="flex flex-wrap items-center gap-1.5">
                <span class={`rounded-md border border-solid px-2 py-0.5 text-caption font-caption ${CLASS_STYLE[c.class]}`}>{CLASS_LABEL[c.class]}</span>
                {c.implementations.length > 0
                  ? c.implementations.map((impl) => (
                      <span class="inline-flex items-center gap-1 rounded-md border border-solid border-neutral-200 bg-default-background px-2 py-0.5 text-caption font-caption text-subtext-color" title={`${impl.vendor} — tools/${impl.tool}`}>
                        <VendorIcon vendor={impl.vendor} logo={vendorLogo(impl.vendor)} />
                        {impl.vendor}
                      </span>
                    ))
                  : <span class="text-caption font-caption text-subtext-color">one spec, every backend</span>}
              </div>
              <span class="text-caption font-caption text-subtext-color">{c.basis}</span>
            </div>
          ))}
        </div>

        <!-- Skills grouped by neutrality bucket -->
        <div class="flex flex-col gap-1 pt-2">
          <h3 id="vn-skills" class="text-heading-3 font-heading-3 text-default-font scroll-mt-14">Skills by neutrality</h3>
          <p class="text-caption font-caption text-subtext-color max-w-[820px]">
            Every skill placed in its bucket. Hover a portable skill to see which capability contracts it invokes —
            each already has more than one backend, so the skill runs unchanged whichever vendor a project picks.
          </p>
        </div>
        <div class="grid grid-cols-3 gap-4 mobile:grid-cols-1">
          {VERDICT_META.map((v) => {
            const list = skillsByVerdict[v.key];
            const green = v.tone === "success";
            return (
              <div class={`flex flex-col gap-3 rounded-2xl border border-solid px-5 py-4 ${green ? "border-success-200 bg-success-50/40" : "border-error-200 bg-error-50/50"}`}>
                <div class="flex flex-col gap-0.5">
                  <div class="flex items-center gap-2">
                    <span class={`h-2.5 w-2.5 flex-none rounded-full ${green ? "bg-success-500" : "bg-error-500"}`}></span>
                    <span class="text-body-bold font-body-bold text-default-font">{v.label}</span>
                    <span class={`ml-auto flex-none rounded-full px-2 py-0.5 text-caption-bold font-caption-bold ${green ? "bg-success-100 text-success-700" : "bg-error-100 text-error-700"}`}>{list.length}</span>
                  </div>
                  <span class="text-caption font-caption text-subtext-color">{v.def}</span>
                </div>
                <div class="flex flex-wrap content-start gap-1.5 max-h-[360px] overflow-y-auto">
                  {v.key === "vendor-coupled"
                    ? list.map((s) => (
                        <span class="inline-flex flex-col gap-0.5 rounded-md border border-solid border-error-200 bg-default-background px-2 py-1">
                          <span class="font-mono text-caption font-caption text-default-font">{s.skill}</span>
                          <span class="flex flex-wrap items-center gap-1">
                            {s.coupled.map((cp) => (
                              <span class="inline-flex items-center gap-1 rounded bg-error-100 px-1.5 py-0.5 text-caption font-caption text-error-700" title={`Sole backend: ${cp.vendor} for ${cp.contract}`}>
                                <VendorIcon vendor={cp.vendor} logo={vendorLogo(cp.vendor)} size="h-3 w-3" />
                                {cp.vendor} → {shortContract(cp.contract)}
                              </span>
                            ))}
                          </span>
                        </span>
                      ))
                    : list.map((s) => (
                        <span
                          class="inline-flex items-center rounded-md border border-solid border-neutral-200 bg-default-background px-2 py-0.5 font-mono text-caption font-caption text-default-font"
                          title={s.contractsUsed.length ? `Invokes ${s.contractsUsed.map(shortContract).join(", ")}` : "Names no backend"}
                        >
                          {s.skill}
                        </span>
                      ))}
                </div>
              </div>
            );
          })}
        </div>

        {(vn.harness || vn.llm) && (
          <div class="flex flex-col gap-1 pt-4">
            <h3 id="vn-llm" class="text-heading-3 font-heading-3 text-default-font scroll-mt-14">LLM &amp; agent-integration neutrality</h3>
            <p class="text-caption font-caption text-subtext-color max-w-[820px]">
              A different axis from the backend contracts above: which <strong>LLM and agent</strong> Magpie's own
              machinery is tied to. Two fronts — the <strong>agent harness</strong> that drives the skills, and the{" "}
              <strong>model endpoint</strong> that may receive data.
            </p>
          </div>
        )}

        {vn.harness && (
          <div class="flex flex-col gap-4 rounded-2xl border border-solid border-neutral-200 bg-neutral-50 px-5 py-5">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <div class="flex flex-col gap-0.5">
                <span class="text-body-bold font-body-bold text-default-font">Agent harness</span>
                <span class="text-caption font-caption text-subtext-color">
                  Which harness supports each substrate tool. A tool is neutral when it is harness-agnostic or
                  supports two or more harnesses.
                </span>
              </div>
