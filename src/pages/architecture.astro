  <!-- Scroll-spy: highlight the section currently in view in the left nav,
       mirroring the docs sidebar's active-page highlight. -->
  <script is:inline>
    (() => {
      const links = [...document.querySelectorAll("[data-arch-link]")];
      if (!links.length) return;
      let current = null;
      const setActive = (id) => {
        if (id === current) return;
        current = id;
        for (const a of links) {
          const on = a.getAttribute("data-arch-link") === id;
          a.classList.toggle("bg-brand-100", on);
          a.classList.toggle("text-brand-800", on);
          a.classList.toggle("text-default-font", !on);
          if (on) a.setAttribute("aria-current", "true");
          else a.removeAttribute("aria-current");
        }
      };
      const ids = links.map((a) => a.getAttribute("data-arch-link"));
      const lastId = ids[ids.length - 1];
      const sections = ids.map((id) => document.getElementById(id)).filter(Boolean);

      // Near the bottom the last section can never reach the top active-band, so
      // the observer would otherwise leave a higher section highlighted. Force
      // the last item active whenever the page can't scroll any further.
      const atBottom = () =>
        window.innerHeight + Math.ceil(window.scrollY) >=
        document.documentElement.scrollHeight - 2;

      const obs = new IntersectionObserver(
        (entries) => {
          if (atBottom()) return setActive(lastId);
          const visible = entries.filter((e) => e.isIntersecting);
          if (!visible.length) return;
          visible.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
          setActive(visible[0].target.id);
        },
        { rootMargin: "-10% 0px -80% 0px", threshold: 0 },
      );
      for (const s of sections) obs.observe(s);
      window.addEventListener("scroll", () => { if (atBottom()) setActive(lastId); }, { passive: true });

      // Clicking a nav item highlights it right away and keeps it highlighted —
      // important for short sections (e.g. the last one) that the scroll-spy's
      // active-band can't reach.
      for (const a of links) {
        a.addEventListener("click", () => setActive(a.getAttribute("data-arch-link")));
      }
    })();
  </script>

