---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SiteHeader } from "../components/landing/SiteHeader";
import { SiteFooter } from "../components/landing/SiteFooter";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const asset = (p: string) => `${base}${p}`;

// ── Brand color palette ──────────────────────────────────────────────────
// Sourced verbatim from src/theme.css (the Subframe/Tailwind theme tokens the
// whole site renders from) so this page can never drift from the live colors.
const brandBlues = [
  { name: "Brand 900", varName: "--color-brand-900", hex: "#00183E", rgb: "0 24 62", role: "Deep ink · gradient top", dark: true },
  { name: "Brand 800", varName: "--color-brand-800", hex: "#002864", rgb: "0 40 100", role: "Gradient mid", dark: true },
  { name: "Brand 700", varName: "--color-brand-700", hex: "#00398A", rgb: "0 57 138", role: "Hover / pressed", dark: true },
  { name: "Brand 600", varName: "--color-brand-600", hex: "#004AAD", rgb: "0 74 173", role: "Primary — links, buttons, the mark", dark: true, primary: true },
  { name: "Brand 500", varName: "--color-brand-500", hex: "#124DB9", rgb: "18 77 185", role: "Accent", dark: true },
  { name: "Brand 100", varName: "--color-brand-100", hex: "#CFDEFF", rgb: "207 222 255", role: "Subtle borders / dividers", dark: false },
  { name: "Brand 50", varName: "--color-brand-50", hex: "#EBF2FF", rgb: "235 242 255", role: "Tinted surfaces", dark: false },
];
const neutrals = [
  { name: "Ink", varName: "--color-neutral-900", hex: "#141210", rgb: "20 18 16", role: "Default text", dark: true },
  { name: "Subtext", varName: "--color-neutral-500", hex: "#6A7076", rgb: "106 112 118", role: "Secondary text", dark: true },
  { name: "White", varName: "--color-neutral-0", hex: "#FFFFFF", rgb: "255 255 255", role: "Background", dark: false },
];

// ── Typography ───────────────────────────────────────────────────────────
const typefaces = [
  { name: "Jost", role: "Display & headings", weights: "500 · 600", sample: "Give maintainers time back", family: "'Jost', sans-serif", license: "SIL Open Font License 1.1" },
  { name: "Inter", role: "Body & UI", weights: "400 · 500 · 600 · 700", sample: "AI-powered assistance for open-source maintainers.", family: "'Inter', sans-serif", license: "SIL Open Font License 1.1" },
  { name: "Geist Mono", role: "Code & monospace", weights: "Variable", sample: "magpie run --dry-run", family: "'Geist', monospace", license: "SIL Open Font License 1.1" },
];

// ── Social-media asset kit ───────────────────────────────────────────────
// Each platform's currently-recommended avatar + banner dimensions, mapped to
// the ready-made files in /public/brand.
const platforms = [
  {
    name: "X",
    avatar: { file: "/brand/avatar-400.png", dim: "400×400", note: "Displayed as a circle" },
    banner: { file: "/brand/banner-1500x500.png", dim: "1500×500", note: "Header photo" },
  },
  {
    name: "LinkedIn",
    avatar: { file: "/brand/avatar-400.png", dim: "300×300+", note: "Organization logo" },
    banner: { file: "/brand/banner-linkedin-1128x191.png", dim: "1128×191", note: "Page cover" },
  },
  {
    name: "Fosstodon / Mastodon",
    avatar: { file: "/brand/avatar-400.png", dim: "400×400", note: "Rounded square" },
    banner: { file: "/brand/banner-1500x500.png", dim: "1500×500", note: "Profile header" },
  },
  {
    name: "Bluesky",
    avatar: { file: "/brand/avatar-1000.png", dim: "1000×1000", note: "Displayed as a circle" },
    banner: { file: "/brand/banner-bluesky-3000x1000.png", dim: "3000×1000", note: "3:1 banner" },
  },
];
---

<BaseLayout
  title="Brand assets — Apache Magpie"
  description="The Apache Magpie brand book: logo and mark, color palette, typography, and ready-to-use social-media avatars and banners for X, LinkedIn, Fosstodon/Mastodon and Bluesky."
  editUrl="https://github.com/apache/magpie-site/edit/main/src/pages/brand.astro"
>
  <SiteHeader />

  <main class="flex w-full flex-col items-center">
    <!-- Header band -->
    <div class="w-full bg-default-background px-8 pt-16 pb-10 mobile:px-4 mobile:pt-10">
      <header class="mx-auto flex w-full max-w-[900px] flex-col gap-4">
        <a href={`${base}/`} class="text-body font-body text-brand-600 hover:text-brand-700">← Back to Apache Magpie™</a>
        <div class="flex items-center gap-2 self-start rounded-full border border-solid border-brand-200 bg-brand-50 px-4 py-1.5">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-600" aria-hidden="true">
            <circle cx="13.5" cy="6.5" r="2.5" /><circle cx="17.5" cy="10.5" r="2.5" /><circle cx="8.5" cy="7.5" r="2.5" /><circle cx="6.5" cy="12.5" r="2.5" /><path d="M12 2a10 10 0 1 0 0 20 1.5 1.5 0 0 0 1.06-2.56A1.5 1.5 0 0 1 14.12 17H16a4 4 0 0 0 4-4 10 10 0 0 0-8-11Z" />
          </svg>
          <span class="text-caption font-caption text-brand-600">Brand book</span>
        </div>
        <h1 class="font-['Inter'] text-[38px] font-[700] leading-[44px] text-default-font -tracking-[0.035em] mobile:text-[28px]">
          Brand assets
        </h1>
        <p class="text-body font-body text-subtext-color max-w-[760px]">
          The Apache Magpie™ logo, colors, typography, and ready-made social-media images.
          Everything here is released under the Apache License 2.0 for use when referring to
          the project — subject to the{" "}
          <a class="text-brand-600 hover:text-brand-700 underline" href="https://www.apache.org/foundation/marks/" target="_blank" rel="noreferrer">ASF trademark policy</a>.
        </p>
      </header>
    </div>

    <!-- Body -->
    <div class="w-full px-8 pb-20 mobile:px-4">
      <div class="mx-auto flex w-full max-w-[900px] flex-col gap-6">

        <!-- Logo & mark -->
        <section id="logo" class="flex flex-col gap-5 rounded-2xl border border-solid border-neutral-200 bg-default-background px-6 py-6 shadow-sm scroll-mt-20">
          <div class="flex flex-col gap-1">
            <h2 class="text-heading-2 font-heading-2 text-default-font">Logo &amp; mark</h2>
            <p class="text-body font-body text-subtext-color max-w-[720px]">
              The mark is the letter <strong>M</strong> holding a magpie. Use the mark on its
              own for square contexts (avatars, app icons) and the wordmark or full lockup where
              there is room. Keep clear space around the logo equal to the height of the bird's
              eye, and never recolor, rotate, stretch, or add effects to it.
            </p>
          </div>
          <div class="grid grid-cols-3 gap-4 mobile:grid-cols-1">
            <!-- Mark -->
            <div class="flex flex-col gap-3">
              <div class="flex h-40 items-center justify-center rounded-xl border border-solid border-neutral-200 bg-brand-50">
                <img src={asset("/mark.svg")} alt="Apache Magpie mark" class="h-24 w-24 object-contain" />
              </div>
              <div class="flex items-center justify-between gap-2">
                <span class="text-body-bold font-body-bold text-default-font">Mark</span>
                <span class="flex items-center gap-2 text-caption font-caption">
                  <a class="text-brand-600 hover:text-brand-700 underline" href={asset("/mark.svg")} download>SVG</a>
                  <a class="text-brand-600 hover:text-brand-700 underline" href={asset("/magpie-mark.png")} download>PNG</a>
                </span>
              </div>
            </div>
            <!-- Wordmark -->
            <div class="flex flex-col gap-3">
              <div class="flex h-40 items-center justify-center rounded-xl border border-solid border-neutral-200 bg-default-background px-6">
                <img src={asset("/wordmark.svg")} alt="Apache Magpie wordmark" class="max-h-12 w-full object-contain" />
              </div>
              <div class="flex items-center justify-between gap-2">
                <span class="text-body-bold font-body-bold text-default-font">Wordmark</span>
                <span class="flex items-center gap-2 text-caption font-caption">
                  <a class="text-brand-600 hover:text-brand-700 underline" href={asset("/wordmark.svg")} download>SVG</a>
                </span>
              </div>
            </div>
            <!-- Mark on dark -->
            <div class="flex flex-col gap-3">
              <div class="flex h-40 items-center justify-center rounded-xl border border-solid border-brand-900 bg-brand-900">
                <img src={asset("/brand/avatar-400.png")} alt="Apache Magpie mark on a light tile" class="h-24 w-24 rounded-2xl object-contain" />
              </div>
              <div class="flex items-center justify-between gap-2">
                <span class="text-body-bold font-body-bold text-default-font">Avatar tile</span>
                <span class="flex items-center gap-2 text-caption font-caption">
                  <a class="text-brand-600 hover:text-brand-700 underline" href={asset("/brand/avatar-400.png")} download>400</a>
                  <a class="text-brand-600 hover:text-brand-700 underline" href={asset("/brand/avatar-1000.png")} download>1000</a>
                </span>
              </div>
            </div>
          </div>
        </section>

        <!-- Colors -->
        <section id="colors" class="flex flex-col gap-5 rounded-2xl border border-solid border-neutral-200 bg-default-background px-6 py-6 shadow-sm scroll-mt-20">
          <div class="flex flex-col gap-1">
            <h2 class="text-heading-2 font-heading-2 text-default-font">Colors</h2>
            <p class="text-body font-body text-subtext-color max-w-[720px]">
              Magpie blue (<strong>Brand 600</strong>, <code class="font-mono">#004AAD</code>) is the
              primary color. The darker shades build the hero gradient; the light tints are for
              surfaces and borders.
            </p>
          </div>
          <div class="flex flex-col gap-2">
            {brandBlues.map((c) => (
              <div class="flex items-center gap-4 rounded-xl border border-solid border-neutral-200 px-3 py-2.5">
                <div class="h-12 w-12 flex-none rounded-lg border border-solid border-neutral-200" style={`background:${c.hex}`}></div>
                <div class="flex flex-1 flex-wrap items-baseline gap-x-3 gap-y-0.5">
                  <span class="text-body-bold font-body-bold text-default-font">{c.name}</span>
                  {c.primary && <span class="rounded-full bg-brand-50 px-2 py-0.5 text-caption font-caption text-brand-700">Primary</span>}
                  <span class="text-caption font-caption text-subtext-color">{c.role}</span>
                </div>
                <div class="flex flex-none items-center gap-3 font-mono text-caption text-default-font">
                  <span>{c.hex}</span>
                  <span class="text-subtext-color mobile:hidden">rgb({c.rgb})</span>
                </div>
              </div>
            ))}
            {neutrals.map((c) => (
              <div class="flex items-center gap-4 rounded-xl border border-solid border-neutral-200 px-3 py-2.5">
                <div class="h-12 w-12 flex-none rounded-lg border border-solid border-neutral-200" style={`background:${c.hex}`}></div>
                <div class="flex flex-1 flex-wrap items-baseline gap-x-3 gap-y-0.5">
                  <span class="text-body-bold font-body-bold text-default-font">{c.name}</span>
                  <span class="text-caption font-caption text-subtext-color">{c.role}</span>
                </div>
                <div class="flex flex-none items-center gap-3 font-mono text-caption text-default-font">
                  <span>{c.hex}</span>
                  <span class="text-subtext-color mobile:hidden">rgb({c.rgb})</span>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Typography -->
        <section id="type" class="flex flex-col gap-5 rounded-2xl border border-solid border-neutral-200 bg-default-background px-6 py-6 shadow-sm scroll-mt-20">
          <div class="flex flex-col gap-1">
            <h2 class="text-heading-2 font-heading-2 text-default-font">Typography</h2>
            <p class="text-body font-body text-subtext-color max-w-[720px]">
              Three open-source typefaces, self-hosted with the site. All are licensed under the
              SIL Open Font License 1.1, so they can be embedded and rendered freely.
            </p>
          </div>
          <div class="flex flex-col gap-3">
            {typefaces.map((t) => (
              <div class="flex flex-col gap-2 rounded-xl border border-solid border-neutral-200 px-4 py-4">
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                  <span class="text-body-bold font-body-bold text-default-font">{t.name}</span>
                  <span class="text-caption font-caption text-subtext-color">{t.role}</span>
                  <span class="text-caption font-caption text-subtext-color">· {t.weights}</span>
                  <span class="ml-auto rounded-full bg-brand-50 px-2 py-0.5 text-caption font-caption text-brand-700">OFL 1.1</span>
                </div>
                <p class="text-[26px] leading-tight text-default-font" style={`font-family:${t.family}`}>{t.sample}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Social media kit -->
        <section id="social" class="flex flex-col gap-5 rounded-2xl border border-solid border-neutral-200 bg-default-background px-6 py-6 shadow-sm scroll-mt-20">
          <div class="flex flex-col gap-1">
            <h2 class="text-heading-2 font-heading-2 text-default-font">Social media kit</h2>
            <p class="text-body font-body text-subtext-color max-w-[720px]">
              Ready-to-upload avatars and banners at each platform's recommended size. The avatar
              is the mark on a white tile so it stays legible inside circular crops; the banner is
              the full lockup on the brand gradient. Keep key content centered — some platforms
              overlay the avatar on the lower-left of the banner.
            </p>
          </div>

          <!-- Link-preview card -->
          <div class="flex flex-col gap-3">
            <div class="flex items-center justify-between gap-2">
              <span class="text-body-bold font-body-bold text-default-font">Link-preview card</span>
              <span class="flex items-center gap-2 text-caption font-caption">
                <span class="text-subtext-color">1200×630</span>
                <a class="text-brand-600 hover:text-brand-700 underline" href={asset("/og-image.png")} download>Download PNG</a>
              </span>
            </div>
            <img src={asset("/og-image.png")} alt="Apache Magpie link-preview card" class="w-full rounded-xl border border-solid border-neutral-200" />
            <p class="text-caption font-caption text-subtext-color">
              Served automatically as the Open Graph / Twitter card when a Magpie link is shared.
            </p>
          </div>

          <!-- Per-platform -->
          <div class="grid grid-cols-2 gap-4 mobile:grid-cols-1">
            {platforms.map((p) => (
              <div class="flex flex-col gap-3 rounded-xl border border-solid border-neutral-200 px-4 py-4">
                <span class="text-body-bold font-body-bold text-default-font">{p.name}</span>
                <div class="flex items-center gap-3">
                  <img src={asset(p.avatar.file)} alt={`${p.name} avatar`} class="h-16 w-16 flex-none rounded-2xl border border-solid border-neutral-200 object-contain" />
                  <div class="flex flex-col">
                    <span class="text-caption font-caption text-default-font">Avatar · {p.avatar.dim}</span>
                    <span class="text-caption font-caption text-subtext-color">{p.avatar.note}</span>
                    <a class="text-caption font-caption text-brand-600 hover:text-brand-700 underline" href={asset(p.avatar.file)} download>Download</a>
                  </div>
                </div>
                <div class="flex flex-col gap-2">
                  <img src={asset(p.banner.file)} alt={`${p.name} banner`} class="w-full rounded-lg border border-solid border-neutral-200 object-cover" />
                  <div class="flex items-center justify-between gap-2">
                    <span class="text-caption font-caption text-subtext-color">Banner · {p.banner.dim} · {p.banner.note}</span>
                    <a class="text-caption font-caption text-brand-600 hover:text-brand-700 underline" href={asset(p.banner.file)} download>Download</a>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Naming & usage -->
        <section id="naming" class="flex flex-col gap-3 rounded-2xl border border-solid border-neutral-200 bg-default-background px-6 py-6 shadow-sm scroll-mt-20">
          <h2 class="text-heading-2 font-heading-2 text-default-font">Naming &amp; usage</h2>
          <ul class="flex flex-col gap-2 text-body font-body text-subtext-color">
            <li>· Full name on first mention: <strong>Apache&nbsp;Magpie</strong>. &ldquo;Magpie&rdquo; alone is fine afterward.</li>
            <li>· It's a project <em>of</em> the Apache Software Foundation — write &ldquo;Apache Magpie,&rdquo; not &ldquo;Apache's Magpie.&rdquo;</li>
            <li>· Don't alter the mark's colors or proportions, or use it to imply endorsement of a third-party product.</li>
            <li>·
              &ldquo;Apache,&rdquo; &ldquo;Magpie,&rdquo; and the Magpie logo are trademarks of the ASF. Usage is governed by the{" "}
              <a class="text-brand-600 hover:text-brand-700 underline" href="https://www.apache.org/foundation/marks/" target="_blank" rel="noreferrer">ASF trademark policy</a>.
            </li>
          </ul>
        </section>

      </div>
    </div>
  </main>

  <SiteFooter />
</BaseLayout>
