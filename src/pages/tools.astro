---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SiteHeader } from "../components/landing/SiteHeader";
import { SiteFooter } from "../components/landing/SiteFooter";
import { buildToolsView } from "../lib/tools-view";
import VendorIcon from "../components/VendorIcon.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const {
  data,
  tools,
  contractList,
  substrateList,
  orgChips,
  agnosticCount,
  vendorChips,
  interfaceCount,
  labelDefs,
  orgById,
  isImplementation,
  vendorLogo,
  orgLogoOf,
  stateBadge,
  maturityBadge,
  labelCls,
} = buildToolsView(base);

const band = "w-full px-8 py-12 mobile:px-4 mobile:py-8";
const inner = "mx-auto flex w-full max-w-[1100px] flex-col gap-5";
const ARCHITECTURE = `${base}/architecture`;
---

<BaseLayout
  title="Tools — Apache Magpie"
  description={`Browse the ${tools.length} Apache Magpie tools — filter by the contract or substrate they provide, by backend vendor, by organization, or by whether they wrap an MCP server. Generated from the framework repo.`}
  editUrl="https://github.com/apache/magpie-site/edit/main/src/pages/tools.astro"
>
  <SiteHeader />

  <main class="flex w-full flex-col items-center">
    <!-- Header band -->
    <div class="w-full bg-default-background px-8 pt-16 pb-8 mobile:px-4 mobile:pt-10">
      <header class="mx-auto flex w-full max-w-[1100px] flex-col gap-4">
        <a href={`${base}/`} class="text-body font-body text-brand-600 hover:text-brand-700">← Back to Apache Magpie™</a>
        <div class="flex items-center gap-2 self-start rounded-full border border-solid border-brand-200 bg-brand-50 px-4 py-1.5">
          <span class="text-caption font-caption text-brand-600">Tools</span>
        </div>
        <h1 class="font-['Inter'] text-[38px] font-[700] leading-[44px] text-default-font -tracking-[0.035em] mobile:text-[28px]">
          Browse the {tools.length} tools
        </h1>
        <p class="text-body font-body text-subtext-color max-w-[800px]">
          Every Apache Magpie™ tool provides a <strong>contract</strong> (a capability interface skills call) or a{" "}
          <strong>substrate</strong> (a low-level primitive). Filter by capability, <strong>backend vendor</strong>,
          organization, or whether a tool wraps an MCP server — the dimensions combine. Everything here is generated
          directly from{" "}
          <a class="text-brand-600 hover:text-brand-700 underline" href="https://github.com/apache/magpie" target="_blank" rel="noreferrer">apache/magpie</a>.
          For how the pieces fit together, see the{" "}
          <a class="text-brand-600 hover:text-brand-700 underline" href={ARCHITECTURE}>Architecture</a> page.
        </p>
        <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-caption font-caption text-subtext-color">
          <span><strong class="text-default-font">{data.contractsTotal}</strong> tools across {Object.keys(data.contracts).length} contracts</span>
          <span><strong class="text-default-font">{data.substratesTotal}</strong> substrate tools</span>
          <span><strong class="text-default-font">{data.implementedTotal}</strong> implemented</span>
          <span><strong class="text-default-font">{data.mcpTotal}</strong> wrap an MCP server</span>
        </div>
      </header>
    </div>

    <!-- Tools grid + filter -->
    <section class={`${band} bg-neutral-50`}>
      <div class={inner}>
        {/* Sticky filter toolbar. Each dimension is a labelled dropdown of
            checkboxes (multi-select, AND across dimensions); a count badge shows
            how many are active. Stays pinned to the top of the viewport while
            you scroll the grid. */}
        <div id="cap-filters" class="sticky top-0 z-40 flex flex-col gap-2 rounded-xl border border-solid border-neutral-200 bg-default-background/95 px-4 py-3 shadow-sm backdrop-blur">
          <div class="flex flex-wrap items-center gap-2">
            <span class="mr-1 text-caption-bold font-caption-bold uppercase tracking-wider text-subtext-color">Filter</span>

            <details class="filter-dd relative" data-dim="cap-contract">
              <summary class="filter-trigger">
                <span>Contract</span>
                <span data-badge class="hidden rounded-full bg-brand-100 px-1.5 text-caption-bold font-caption-bold text-brand-700">0</span>
                <svg class="filter-chevron size-3 text-subtext-color" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6" /></svg>
              </summary>
              <div class="filter-panel">
                {contractList.map((c) => (
                  <label class="filter-opt" title={c.def}>
                    <input type="checkbox" class="filter-cb size-3.5 accent-brand-600" data-dim="cap" value={`contract:${c.key}`} />
                    <span class="flex-1 font-mono text-caption text-default-font">{c.key}</span>
                    <span class="text-caption text-subtext-color">{c.count}</span>
                  </label>
                ))}
              </div>
            </details>

            <details class="filter-dd relative" data-dim="cap-substrate">
              <summary class="filter-trigger">
                <span>Substrate</span>
                <span data-badge class="hidden rounded-full bg-brand-100 px-1.5 text-caption-bold font-caption-bold text-brand-700">0</span>
                <svg class="filter-chevron size-3 text-subtext-color" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6" /></svg>
              </summary>
              <div class="filter-panel">
                {substrateList.map((s) => (
                  <label class="filter-opt" title={s.def}>
                    <input type="checkbox" class="filter-cb size-3.5 accent-brand-600" data-dim="cap" value={`substrate:${s.key}`} />
                    <span class="flex-1 font-mono text-caption text-default-font">{s.key}</span>
                    <span class="text-caption text-subtext-color">{s.count}</span>
                  </label>
                ))}
              </div>
            </details>

            <details class="filter-dd relative" data-dim="org">
              <summary class="filter-trigger">
                <span>Organization</span>
                <span data-badge class="hidden rounded-full bg-brand-100 px-1.5 text-caption-bold font-caption-bold text-brand-700">0</span>
                <svg class="filter-chevron size-3 text-subtext-color" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6" /></svg>
              </summary>
              <div class="filter-panel">
                {orgChips.map((o) => (
                  <label class="filter-opt" title={`Tools that declare organization: ${o.id} (${o.label})`}>
                    <input type="checkbox" class="filter-cb size-3.5 accent-brand-600" data-dim="org" value={o.id} />
                    {o.logo
                      ? <img src={o.logo} alt={o.id} class="h-3.5 w-auto flex-none" loading="lazy" />
                      : null}
                    <span class="flex-1 font-mono text-caption text-default-font">{o.id}</span>
                    <span class="text-caption text-subtext-color">{o.count}</span>
                  </label>
                ))}
                <label class="filter-opt" title="Organization-agnostic tools (no organization declared)">
                  <input type="checkbox" class="filter-cb size-3.5 accent-brand-600" data-dim="org" value="__agnostic" />
                  <span class="flex-1 text-caption text-default-font">agnostic</span>
                  <span class="text-caption text-subtext-color">{agnosticCount}</span>
                </label>
              </div>
            </details>

            <details class="filter-dd relative" data-dim="vendor">
              <summary class="filter-trigger">
                <span>Vendor</span>
                <span data-badge class="hidden rounded-full bg-brand-100 px-1.5 text-caption-bold font-caption-bold text-brand-700">0</span>
                <svg class="filter-chevron size-3 text-subtext-color" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6" /></svg>
              </summary>
              <div class="filter-panel">
                {vendorChips.map((v) => (
                  <label class="filter-opt" title={`Adapters backed by ${v.vendor}`}>
                    <input type="checkbox" class="filter-cb size-3.5 accent-brand-600" data-dim="vendor" value={v.vendor} />
                    <VendorIcon vendor={v.vendor} logo={v.logo} />
                    <span class="flex-1 text-caption text-default-font">{v.vendor}</span>
                    <span class="text-caption text-subtext-color">{v.count}</span>
                  </label>
                ))}
                <label class="filter-opt" title="Pure interface specs — a contract with no vendor code, waiting for adapters">
                  <input type="checkbox" class="filter-cb size-3.5 accent-brand-600" data-dim="vendor" value="__interface" />
                  <span class="flex-1 text-caption text-default-font">interface specs</span>
                  <span class="text-caption text-subtext-color">{interfaceCount}</span>
                </label>
              </div>
            </details>

            <button type="button" data-mcp="1" aria-pressed="false" title="Tools that wrap a Model Context Protocol (MCP) server as their backend" class="filter-toggle">
              Wraps an MCP{" "}
              <span class="rounded-full bg-neutral-100 px-1.5 text-caption text-subtext-color">{data.mcpTotal}</span>
            </button>

            <button type="button" id="cap-clear" hidden class="inline-flex items-center gap-1 rounded-md px-2.5 py-1.5 text-caption font-caption text-subtext-color hover:bg-neutral-100 hover:text-brand-700">Clear ✕</button>

            <span id="cap-status-text" class="ml-auto text-caption font-caption text-subtext-color">Showing all {tools.length} tools.</span>
          </div>
          <div id="cap-status-defs" class="flex flex-col gap-0.5 empty:hidden"></div>
        </div>

        <div id="tools-grid" class="grid grid-cols-2 gap-4 mobile:grid-cols-1">
          {tools.map((t) => {
            const sb = stateBadge(t);
            const mb = maturityBadge(t.maturity);
            const org = t.organization ? orgById[t.organization] : null;
            const impl = isImplementation(t);
            const vlogo = impl ? vendorLogo(t.vendor) : null;
            return (
              <a
                href={`${base}/docs/tools/${t.name}/readme`}
                data-caps={t.labels.map((l) => `${l.kind}:${l.name}`).join(" ")}
                data-org={t.organization ?? "__agnostic"}
                data-mcp={t.mcp ? "1" : "0"}
                data-vendor={impl ? t.vendor : ""}
                data-interface={t.vendorKind === "interface" ? "1" : "0"}
                class="tool-card group flex h-full flex-col gap-3 rounded-2xl border border-solid border-neutral-200 bg-default-background px-5 py-5 shadow-sm hover:border-brand-200 hover:shadow-md transition-all"
              >
                <div class="flex items-start justify-between gap-3">
                  <div class="flex flex-col gap-0.5">
                    <span class="text-body-bold font-body-bold text-default-font group-hover:text-brand-700">{t.title}</span>
                    <span class="font-mono text-caption font-caption text-subtext-color">tools/{t.name}</span>
                  </div>
                  <div class="flex flex-none flex-wrap justify-end gap-1.5">
                    {impl && t.vendor && (
                      <span class="inline-flex items-center gap-1 rounded-full border border-solid border-neutral-200 bg-default-background px-2 py-0.5 text-caption font-caption text-default-font" title={`Backend vendor: ${t.vendor}`}>
                        <VendorIcon vendor={t.vendor} logo={vlogo} />
                        {t.vendor}
                      </span>
                    )}
                    {t.vendorKind === "interface" && (
                      <span class="inline-flex items-center gap-1 rounded-full border border-solid border-neutral-200 bg-neutral-50 px-2 py-0.5 text-caption font-caption text-subtext-color" title="Pure interface spec — no vendor code; adapters implement it per backend">
                        interface
                      </span>
                    )}
                    {org && (
                      <span class="inline-flex items-center gap-1 rounded-full border border-solid border-neutral-200 bg-default-background px-2 py-0.5 text-caption font-caption text-subtext-color" title={`Organization: ${org.name}`}>
                        {orgLogoOf(org)
                          ? <img src={orgLogoOf(org)} alt={org.name} class="h-3.5 w-auto" loading="lazy" />
                          : org.id}
                      </span>
                    )}
                    {t.mcp && (
                      <span class="inline-flex items-center gap-1 rounded-full border border-solid border-brand-300 bg-brand-100 px-2 py-0.5 text-caption font-caption text-brand-700" title={`Wraps ${t.mcp.server} (${t.mcp.prefix})`}>
                        <span aria-hidden="true">🔌</span> MCP
                      </span>
                    )}
                    <span class={`rounded-full border border-solid px-2 py-0.5 text-caption font-caption ${sb.cls}`}>{sb.label}</span>
                    {mb && <span class={`rounded-full border border-solid px-2 py-0.5 text-caption font-caption ${mb.cls}`}>{mb.label}</span>}
                  </div>
                </div>
                <p class="text-caption font-caption text-subtext-color">{t.description}</p>
                {t.mcp && (
                  <p class="rounded-md bg-brand-50 px-2.5 py-1.5 text-caption font-caption text-brand-700">
                    Wraps the <strong>{t.mcp.server}</strong> via{" "}
                    <span class="font-mono">{t.mcp.prefix}</span> — the MCP is just the transport behind the
                    contract; a CLI or REST backend can fulfil the same capability.
                  </p>
                )}
                <div class="mt-auto flex flex-wrap gap-1.5 pt-1">
                  {t.labels.map((l) => (
                    <span class={`rounded-md px-2 py-0.5 font-mono text-caption font-caption ${labelCls(l.kind)}`}>{l.kind}:{l.name}</span>
                  ))}
                </div>
              </a>
            );
          })}
        </div>
        <p id="tools-empty" hidden class="rounded-2xl border border-dashed border-neutral-300 px-4 py-6 text-center text-body font-body text-subtext-color">
          No tools match the selected filters.
        </p>
      </div>
    </section>
  </main>

  <SiteFooter />

  <script is:inline define:vars={{ labelDefs, total: tools.length }}>
    const bar = document.getElementById("cap-filters");
    if (bar) {
      const checkboxes = [...bar.querySelectorAll("input.filter-cb")];
      const dropdowns = [...bar.querySelectorAll("details.filter-dd")];
      const mcpToggle = bar.querySelector("[data-mcp]");
      const clearBtn = document.getElementById("cap-clear");
      const cards = [...document.querySelectorAll("#tools-grid .tool-card")];
      const statusText = document.getElementById("cap-status-text");
      const statusDefs = document.getElementById("cap-status-defs");
      const empty = document.getElementById("tools-empty");

      const orgLabel = (id) => (id === "__agnostic" ? "agnostic" : id);
      const vendorLabel = (v) => (v === "__interface" ? "interface specs" : v);

      function readActive() {
        const caps = [], orgs = [], vendors = [];
        for (const cb of checkboxes) {
          if (!cb.checked) continue;
          if (cb.dataset.dim === "cap") caps.push(cb.value);
          else if (cb.dataset.dim === "org") orgs.push(cb.value);
          else if (cb.dataset.dim === "vendor") vendors.push(cb.value);
        }
        const mcpOnly = !!mcpToggle && mcpToggle.getAttribute("aria-pressed") === "true";
        return { caps, orgs, vendors, mcpOnly };
      }

      function apply() {
        const { caps, orgs, vendors, mcpOnly } = readActive();
        const none = caps.length === 0 && orgs.length === 0 && vendors.length === 0 && !mcpOnly;
        let shown = 0;
        for (const card of cards) {
          const cardCaps = (card.dataset.caps || "").split(" ").filter(Boolean);
          const capMatch = caps.length === 0 || caps.some((c) => cardCaps.includes(c));
          const orgMatch = orgs.length === 0 || orgs.includes(card.dataset.org);
          const vendorMatch =
            vendors.length === 0 ||
            vendors.some((v) => (v === "__interface" ? card.dataset.interface === "1" : card.dataset.vendor === v));
          const mcpMatch = !mcpOnly || card.dataset.mcp === "1";
          const match = capMatch && orgMatch && vendorMatch && mcpMatch;
          card.hidden = !match;
          if (match) shown++;
        }

        // Per-dropdown active-count badge + active styling on the trigger.
        for (const dd of dropdowns) {
          const n = dd.querySelectorAll("input.filter-cb:checked").length;
          const badge = dd.querySelector("[data-badge]");
          const trigger = dd.querySelector(".filter-trigger");
          if (badge) { badge.textContent = String(n); badge.classList.toggle("hidden", n === 0); }
          if (trigger) trigger.classList.toggle("is-active", n > 0);
        }
        if (mcpToggle) mcpToggle.classList.toggle("is-active", mcpOnly);

        clearBtn.hidden = none;
        empty.hidden = shown !== 0;

        if (none) {
          statusText.textContent = `Showing all ${total} tools.`;
          statusDefs.innerHTML = "";
          return;
        }
        const parts = [];
        if (caps.length) parts.push(`provide ${caps.length === 1 ? "" : "any of "}${caps.join(", ")}`);
        if (vendors.length) parts.push(`are backed by ${vendors.map(vendorLabel).join(" / ")}`);
        if (orgs.length) parts.push(`belong to ${orgs.map(orgLabel).join(" / ")}`);
        if (mcpOnly) parts.push("wrap an MCP server");
        statusText.textContent = `Showing ${shown} of ${total} tools that ${parts.join(" and ")}.`;
        statusDefs.innerHTML = caps
          .map(
            (c) =>
              `<span class="text-caption font-caption text-subtext-color"><span class="font-mono text-default-font">${c}</span> — ${labelDefs[c] || ""}</span>`,
          )
          .join("");
      }

      for (const cb of checkboxes) cb.addEventListener("change", apply);
      if (mcpToggle) {
        mcpToggle.addEventListener("click", () => {
          const on = mcpToggle.getAttribute("aria-pressed") === "true";
          mcpToggle.setAttribute("aria-pressed", on ? "false" : "true");
          apply();
        });
      }
      clearBtn.addEventListener("click", () => {
        for (const cb of checkboxes) cb.checked = false;
        if (mcpToggle) mcpToggle.setAttribute("aria-pressed", "false");
        for (const dd of dropdowns) dd.open = false;
        apply();
      });

      // One dropdown open at a time; close on outside click or Escape.
      for (const dd of dropdowns) {
        dd.addEventListener("toggle", () => {
          if (dd.open) for (const other of dropdowns) if (other !== dd) other.open = false;
        });
      }
      document.addEventListener("click", (e) => {
        if (!bar.contains(e.target)) for (const dd of dropdowns) dd.open = false;
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") for (const dd of dropdowns) dd.open = false;
      });

      apply();
    }
  </script>

  <style>
    .filter-trigger {
      display: inline-flex; align-items: center; gap: 0.375rem;
      cursor: pointer; user-select: none; list-style: none;
      border: 1px solid var(--color-neutral-300); border-radius: 0.375rem;
      background: var(--color-default-background); padding: 0.375rem 0.75rem;
      font-size: 0.8125rem; line-height: 1; color: var(--color-default-font);
    }
    .filter-trigger::-webkit-details-marker { display: none; }
    .filter-trigger:hover { border-color: var(--color-brand-300); }
    .filter-trigger.is-active {
      border-color: var(--color-brand-400);
      background: var(--color-brand-50); color: var(--color-brand-700);
    }
    details[open] > .filter-trigger { border-color: var(--color-brand-400); }
    .filter-chevron { transition: transform 0.15s ease; }
    details[open] > .filter-trigger .filter-chevron { transform: rotate(180deg); }
    .filter-panel {
      position: absolute; left: 0; top: 100%; margin-top: 0.375rem; z-index: 50;
      width: 16rem; max-height: 20rem; overflow-y: auto;
      border: 1px solid var(--color-neutral-200); border-radius: 0.5rem;
      background: var(--color-default-background); padding: 0.375rem;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    }
    .filter-opt {
      display: flex; align-items: center; gap: 0.5rem; cursor: pointer;
      border-radius: 0.375rem; padding: 0.375rem 0.5rem;
    }
    .filter-opt:hover { background: var(--color-neutral-50); }
    .filter-toggle {
      display: inline-flex; align-items: center; gap: 0.375rem; cursor: pointer;
      border: 1px solid var(--color-neutral-300); border-radius: 0.375rem;
      background: var(--color-default-background); padding: 0.375rem 0.75rem;
      font-size: 0.8125rem; line-height: 1; color: var(--color-default-font);
    }
    .filter-toggle:hover { border-color: var(--color-brand-300); }
    .filter-toggle.is-active {
      border-color: var(--color-brand-400);
      background: var(--color-brand-50); color: var(--color-brand-700);
    }
  </style>
</BaseLayout>
